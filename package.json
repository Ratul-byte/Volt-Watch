{
  "name": "voltwatch",
  "version": "1.0.0",
  "description": "PC Electricity Bill Monitor for Bangladesh",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win --x64",
    "build-portable": "electron-builder build --win portable"
  },
  "build": {
    "appId": "com.voltwatch.app",
    "productName": "VoltWatch",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "systeminformation": "^5.21.0",
    "electron-store": "^8.1.0"
  }
}
